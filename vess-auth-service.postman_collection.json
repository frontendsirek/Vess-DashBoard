            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/health/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "health", ""]
            },
            "description": "Returns auth-service health status including database and cache checks."
          },
          "response": []
        },
        {
          "name": "Root Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health/",
              "host": ["{{baseUrl}}"],
              "path": ["health", ""]
            },
            "description": "Simple liveness probe at the root path."
          },
          "response": []
        },
        {
          "name": "System Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/system/health/",
              "host": ["{{baseUrl}}"],
              "path": ["system", "health", ""]
