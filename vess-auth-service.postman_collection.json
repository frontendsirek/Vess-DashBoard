                }
              ]
            },
            "description": "List all users. Admin only (`is_staff=True`). Supports optional `?search=<email>` query param."
          },
          "response": []
        },
        {
          "name": "Get User by ID (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/1/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "1", ""]
            },
            "description": "Retrieve a user by their numeric ID. Admin only."
          },
          "response": []
        },
        {
          "name": "Update User by ID (Admin)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Admin\",\n  \"last_name\": \"Updated\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/1/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "1", ""]
            },
            "description": "Update a user by their numeric ID. Admin only."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Service-to-Service",
      "item": [
        {
          "name": "Validate Token",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Build HMAC-SHA256 signature matching verify_hmac_signature() in utils.py",
                  "// message = serviceId + timestamp + body",
                  "const serviceId = 'device-service';",
                  "const secret = pm.collectionVariables.get('deviceServiceSecret') || 'device-secret-key';",
                  "const timestamp = String(Math.floor(Date.now() / 1000));",
                  "const token = pm.collectionVariables.get('accessToken') || '';",
                  "const body = JSON.stringify({ token });",
                  "",
                  "const message = serviceId + timestamp + body;",
                  "",
                  "const signature = CryptoJS.HmacSHA256(message, secret).toString(CryptoJS.enc.Hex);",
                  "",
                  "pm.request.headers.add({ key: 'X-Service-Id', value: serviceId });",
                  "pm.request.headers.add({ key: 'X-Hmac-Signature', value: signature });",
                  "pm.request.headers.add({ key: 'X-Timestamp', value: timestamp });",
                  "",
                  "// Overwrite the raw body with the exact string that was signed",
                  "pm.request.body.raw = body;"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{accessToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/validate/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "validate", ""]
            },
            "description": "Service-to-service endpoint. Validates a JWT access token and checks its session is still active in cache.\n\nThe pre-request script automatically computes the HMAC-SHA256 signature using the `deviceServiceSecret` variable. Set that variable to match `DEVICE_SERVICE_SECRET` on the server."
          },
          "response": []
        },
        {
          "name": "Get Internal User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const serviceId = 'device-service';",
                  "const secret = pm.collectionVariables.get('deviceServiceSecret') || 'device-secret-key';",
                  "const timestamp = String(Math.floor(Date.now() / 1000));",
                  "const body = '';",
                  "",
                  "const message = serviceId + timestamp + body;",
                  "const signature = CryptoJS.HmacSHA256(message, secret).toString(CryptoJS.enc.Hex);",
                  "",
                  "pm.request.headers.add({ key: 'X-Service-Id', value: serviceId });",
                  "pm.request.headers.add({ key: 'X-Hmac-Signature', value: signature });",
                  "pm.request.headers.add({ key: 'X-Timestamp', value: timestamp });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/internal/1/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "internal", "1", ""]
            },
            "description": "Fetch a user's details for internal service communication. Replace `1` with the target user ID. Requires valid HMAC headers (auto-generated by the pre-request script)."
          },
          "response": []
        }
      ]
    }
  ]
}
