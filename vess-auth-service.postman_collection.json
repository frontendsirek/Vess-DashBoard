{
  "info": {
    "name": "Vess Auth Service",
    "_postman_id": "vess-auth-service-collection",
    "description": "Complete collection for the Vess Auth Service API.\n\n**Setup:**\n1. Set the `baseUrl` collection variable to your deployment URL (default points to the ALB).\n2. Set `deviceServiceSecret` to match `DEVICE_SERVICE_SECRET` on the server (used for HMAC-signed service-to-service calls).\n3. Run requests in order — login/verify-otp responses auto-populate `accessToken` and `refreshToken` variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://vess-dev-alb-385758613.us-east-1.elb.amazonaws.com/auth",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "deviceServiceSecret",
      "value": "device-secret-key",
      "type": "string"
    },
    {
      "key": "testEmail",
      "value": "integration@vess-test.com",
      "type": "string"
    },
    {
      "key": "testPassword",
      "value": "IntegrationPass123!",
      "type": "string"
    },
    {
      "key": "resetToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
