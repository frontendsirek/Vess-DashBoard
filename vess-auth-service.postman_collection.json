    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('otp', body.data.otp_for_testing);",
                  "    pm.collectionVariables.set('registeredUserId', body.data.user.id);",
                  "    console.log('OTP:', body.data.otp_for_testing);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"password_confirm\": \"{{testPassword}}\",\n  \"first_name\": \"Integration\",\n  \"last_name\": \"Test\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register", ""]
            },
            "description": "Register a new user. Returns an OTP in `data.otp_for_testing` (dev/staging only). The OTP is auto-saved to the `otp` collection variable."
          },
          "response": []
        },
        {
          "name": "Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', body.data.access_token);",
                  "    pm.collectionVariables.set('refreshToken', body.data.refresh_token);",
                  "    console.log('Tokens saved from OTP verify.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/verify-otp/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "verify-otp", ""]
            },
            "description": "Verify the 6-digit OTP sent after registration. Activates the account and returns JWT tokens. Tokens are auto-saved to `accessToken` and `refreshToken`."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', body.data.access_token);",
                  "    pm.collectionVariables.set('refreshToken', body.data.refresh_token);",
                  "    console.log('Tokens saved from login.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login", ""]
            },
            "description": "Authenticate with email and password. Returns `access_token` and `refresh_token`. Both are auto-saved to collection variables."
          },
          "response": []
        },
        {
          "name": "Google Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_token\": \"<google-oauth-id-token>\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/google/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "google", ""]
            },
            "description": "Login or register via a Google OAuth2 ID token. Requires `GOOGLE_CLIENT_ID` to be configured on the server."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', body.data.access);",
                  "    pm.collectionVariables.set('refreshToken', body.data.refresh);",
                  "    console.log('Tokens rotated from refresh.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "refresh", ""]
            },
            "description": "Exchange a refresh token for a new access/refresh token pair. The old refresh token is blacklisted. New tokens are auto-saved."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "logout", ""]
            },
            "description": "Invalidates the access token session in cache and blacklists the refresh token. Requires `Authorization: Bearer <accessToken>`."
          },
          "response": []
        },
        {
          "name": "Password Reset — Request",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    if (body.data && body.data.token_for_testing) {",
                  "        pm.collectionVariables.set('resetToken', body.data.token_for_testing);",
                  "        console.log('Reset token saved:', body.data.token_for_testing);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/password-reset/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "password-reset", ""]
            },
            "description": "Request a password reset email. Always returns 200 to prevent account enumeration. In dev/staging, `data.token_for_testing` is returned and auto-saved."
          },
          "response": []
        },
        {
          "name": "Password Reset — Confirm",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"token\": \"{{resetToken}}\",\n  \"new_password\": \"NewPassword123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/password-reset/confirm/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "password-reset", "confirm", ""]
            },
            "description": "Confirm a password reset using the token from the reset email (or `resetToken` variable). Sets the new password."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/me/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "me", ""]
            },
            "description": "Returns the authenticated user's profile. Requires a valid `accessToken`."
          },
          "response": []
        },
        {
          "name": "Update My Profile",
          "request": {
