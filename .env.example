# ──────────────────────────────────────────────
# VESS Dashboard – Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# All client-side vars MUST start with VITE_

# API base URL — used in dev and prod (axios goes here directly; no Vite proxy). No trailing slash.
VITE_API_BASE_URL=http://vess-dev-alb-385758613.us-east-1.elb.amazonaws.com

# Test service tenant header (sent as X-Tenant-Id on /test/v1/* requests). Placeholder until real tenant auth.
VITE_TEST_TENANT_ID=default-tenant
