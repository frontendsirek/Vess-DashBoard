# ──────────────────────────────────────────────
# VESS Dashboard – Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# All client-side vars MUST start with VITE_

# ── Local development only ──────────────────
# API base URL — used by axios in dev (hits the backend directly).
# In production (Vercel) leave this UNSET; requests go through the /api serverless proxy.
VITE_API_BASE_URL=http://vess-dev-alb-385758613.us-east-1.elb.amazonaws.com

# Test service tenant header (sent as X-Tenant-Id on /test/v1/* requests). Placeholder until real tenant auth.
VITE_TEST_TENANT_ID=default-tenant

# ── Vercel (server-side) ────────────────────
# Set these in the Vercel dashboard → Settings → Environment Variables.
# They are NEVER exposed to the browser.
#
# API_BASE_URL=http://vess-dev-alb-385758613.us-east-1.elb.amazonaws.com
