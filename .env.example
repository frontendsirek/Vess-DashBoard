# ──────────────────────────────────────────────
# VESS Dashboard – Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# ── Local development ───────────────────────
# Backend URL used by the Vite dev proxy (server-side only, NEVER exposed to browser).
API_PROXY_TARGET=https://api-dev.vess-solutions.com

# Test service tenant header (sent as X-Tenant-Id on /test/v1/* requests).
VITE_TEST_TENANT_ID=default-tenant

# ── Production (DigitalOcean / GitHub Actions) ──
# Set these as GitHub repository variables for the deploy workflow.
# VITE_API_BASE_URL=https://api-dev.vess-solutions.com
# VITE_TEST_TENANT_ID=default-tenant

# ── Session / Idle Timeout (all values in milliseconds, optional) ──
# VITE_SESSION_IDLE_TIMEOUT=900000
# VITE_SESSION_PROMPT_BEFORE_IDLE=60000
