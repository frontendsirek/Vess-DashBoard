# ──────────────────────────────────────────────
# VESS Dashboard – Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# ── Local development ───────────────────────
# Backend URL used by the Vite dev proxy (server-side only, NEVER exposed to browser).
API_PROXY_TARGET=http://vess-dev-alb-385758613.us-east-1.elb.amazonaws.com

# Test service tenant header (sent as X-Tenant-Id on /test/v1/* requests).
VITE_TEST_TENANT_ID=default-tenant

# ── Vercel (server-side) ────────────────────
# Set these in the Vercel dashboard → Settings → Environment Variables.
# They are NEVER exposed to the browser.
#
# API_BASE_URL=http://vess-dev-alb-385758613.us-east-1.elb.amazonaws.com
