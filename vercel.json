{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/auth/(.*)", "destination": "/api/proxy?path=/auth/$1" },
    { "source": "/device/(.*)", "destination": "/api/proxy?path=/device/$1" },
    { "source": "/test/(.*)", "destination": "/api/proxy?path=/test/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
